# ldxp 获取数据模式：playwright 使用浏览器上下文；fetch 直接请求接口不打开浏览器。
LDXP_FETCH_MODE=playwright

# ldxp 专用调度策略。
LDXP_MAX_SOURCES_PER_RUN=15
LDXP_DOMAIN_COOLDOWN_HOURS=6
LDXP_DELAY_MIN_MS=8000
LDXP_DELAY_MAX_MS=25000

# 直连请求失败时，通过本机代理重试一次。留空或注释表示不启用。
FALLBACK_PROXY_URL=http://127.0.0.1:7890

# Playwright 模式配置。需要手动过验证时，把 HEADLESS 设为 0，并加大等待时间。
LDXP_PLAYWRIGHT_HEADLESS=1
LDXP_PLAYWRIGHT_MANUAL_WAIT_MS=0
LDXP_PLAYWRIGHT_PROFILE=.playwright-ldxp-profile
LDXP_PLAYWRIGHT_TIMEOUT_MS=60000
LDXP_PLAYWRIGHT_REQUEST_RETRY_ATTEMPTS=4
LDXP_PLAYWRIGHT_REQUEST_RETRY_DELAY_MS=3000

# 暂不建议用于绕 WAF；仅保留兼容已有远端 Playwright 能力。
# LDXP_PLAYWRIGHT_VPS_HOST=vps
# LDXP_PLAYWRIGHT_REMOTE_CWD=/root/codex-price-compare
# LDXP_WINDOWS_TAILSCALE_IP=100.127.136.64

# 补货通知。
STOCK_NOTIFY_ENABLED=1
WEIXIN_GATEWAY_ALERT_URL=http://127.0.0.1:8787/alerts/send
WEIXIN_GATEWAY_ALERT_TARGET=self
